{
  "name": "neckarshore-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --grep-invert @external",
    "test:e2e:ui": "playwright test --ui",
    "test:search:unit": "NODE_ENV=production tsx tests/search/index-data.test.ts",
    "test:smoke": "BASE_URL=https://neckarshore.ai playwright test --grep @smoke",
    "test:smoke:local": "playwright test --grep @smoke",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:quick": "node scripts/lighthouse.mjs --quick",
    "lighthouse:desktop": "node scripts/lighthouse.mjs --quick --profile=desktop",
    "lighthouse:mobile": "node scripts/lighthouse.mjs --quick --profile=mobile-4g",
    "lighthouse:5g": "node scripts/lighthouse.mjs --quick --profile=mobile-5g",
    "test:lighthouse:unit": "node --test scripts/lighthouse-profiles.test.mjs",
    "test:unit": "node --import tsx --test tests/unit/aggregate-test-scope.test.mjs tests/unit/append-test-scope-history.test.mjs tests/unit/disclosure-config.test.mjs tests/unit/export-markdown.test.ts tests/unit/private-slug-leak-gate.test.mjs tests/unit/repo-types.test.ts tests/unit/sitemap.test.ts tests/unit/stats-breakdown.test.ts tests/unit/withhold-private-repos.test.mjs",
    "sync:disclosure-config": "bash scripts/sync-disclosure-config.sh",
    "check:privacy": "bash scripts/check-private-slug-leak.sh",
    "crawl": "node scripts/link-crawler.mjs",
    "crawl:internal": "node scripts/link-crawler.mjs --no-external",
    "crawl:test": "node scripts/link-crawler.mjs --self-test",
    "linkcheck": "node scripts/link-check.mjs",
    "linkcheck:test": "node scripts/link-check.mjs --self-test"
  },
  "dependencies": {
    "@upstash/redis": "1.37.0",
    "gray-matter": "4.0.3",
    "lucide-react": "1.7.0",
    "marked": "18.0.6",
    "minisearch": "7.2.0",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "2.17.5",
    "web-vitals": "5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "2.16.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "lighthouse": "13.4.0",
    "tailwindcss": "^4",
    "tsx": "4.23.0",
    "typescript": "^5"
  }
}
