# GitHub Packages scope pin for @neckarshore-websites/* (e.g. site-quality).
# No secret here — the token is supplied at install time via the NODE_AUTH_TOKEN
# env var: CI sets it from secrets.GITHUB_TOKEN; locally use `export NODE_AUTH_TOKEN=$(gh auth token)`.
@neckarshore-websites:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
